# 复制本文件为 .env，然后只编辑 .env。
# 常规部署不需要修改 compose.yml；config/traefik.yml 只确认静态部署项。

# Cloudflare API 令牌，用于 Traefik 通过 DNS-01 方式申请证书。
# 变量名使用 lego Cloudflare provider 官方主名称 CF_DNS_API_TOKEN。
# 建议权限：只作用于目标 Zone，并授予 Zone 读取和 DNS 编辑权限。
CF_DNS_API_TOKEN=replace-with-cloudflare-dns-token

# Traefik 和业务容器共同加入的外部 Docker 网络。
# 首次启动前需要先创建这个网络：
# docker network create shared_services_net
# 如果改了这个值，业务服务目录里的 .env 也要使用同一个值。
APP_PROXY_NETWORK=shared_services_net

# 泛域名证书的主域名。
# 例如 example.com 会申请 example.com 和 *.example.com。
DOMAIN=example.com

# Traefik 控制台访问域名。
# 通常应使用 DOMAIN 的子域名，例如 traefik.example.com。
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# Traefik 控制台的基础认证（BasicAuth）用户列表。
# 生成方式：
# htpasswd -nbB admin 'your-dashboard-password'
# 或：
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'your-dashboard-password'
# 必须保留单引号，避免 bcrypt 哈希里的 $ 被 Docker Compose 当成变量展开。
TRAEFIK_DASHBOARD_AUTH='admin:replace-with-htpasswd-hash'
