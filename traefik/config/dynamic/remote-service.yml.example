# 远程服务器反向代理模板。
#
# 默认不要把本文件改名为 .yml，Traefik 只会加载 .yml/.yaml/.toml 等动态配置文件。
# 需要代理其他服务器上的服务时，复制本文件：
#
#   cp config/dynamic/remote-service.yml.example config/dynamic/my-service.yml
#
# 然后按真实域名、远程地址、端口和健康检查路径修改。
#
# 适用场景：
# - Traefik 运行在 Server A。
# - 应用运行在 Server B，不能加入 Server A 的 Docker 网络。
# - Server A 可以通过公网 IP、内网 IP、VPC、WireGuard 或 Tailscale 访问 Server B 的服务端口。
# - Server B 防火墙或安全组只允许 Server A 访问该端口。

# http:
#   routers:
#     remote-service-router:
#       rule: Host(`app.example.com`)
#       entryPoints:
#         - websecure
#       middlewares:
#         - default-security-headers@file
#         - compress@file
#       service: remote-service
#       tls:
#         certResolver: letsencrypt
#
#   services:
#     remote-service:
#       loadBalancer:
#         passHostHeader: true
#         servers:
#           # 推荐使用内网/VPC/VPN 地址；公网地址也可以，但必须限制只允许 Traefik 主机访问。
#           - url: http://10.0.2.20:8080
#         healthCheck:
#           # 真实应用建议替换为专用健康检查路径，例如 /health。
#           path: /
#           interval: 30s
#           timeout: 5s
#
#   如果远程后端使用 HTTPS 且需要指定 SNI 或内网 CA，取消下面注释，并在 loadBalancer 下加入：
#
#     serversTransport: remote-service-transport
#
#   serversTransports:
#     remote-service-transport:
#       serverName: app.internal.example.com
#       rootCAs:
#         - /etc/traefik/certs/internal-ca.pem
